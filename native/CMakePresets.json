{
    "version": 6,
    "configurePresets": [
        {
            "name": "release-x64-msvc",
            "displayName": "Release x64 (MSVC + vcpkg)",
            "generator": "Ninja",
            "toolchainFile": "${sourceDir}/../.vcpkg/scripts/buildsystems/vcpkg.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "release",
            "configurePreset": "release-x64-msvc",
            "configuration": "Release"
        }
    ]
}
